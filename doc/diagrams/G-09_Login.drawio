<diagram name="4. Class Diagram" id="4__Class_Diagram"><mxGraphModel pageWidth="1000" pageHeight="860" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Class Diagram — G-09: Login (BCE)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="900" height="38" as="geometry"/></mxCell><mxCell id="2" value="AuthRoutes" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="365" y="65" width="220" height="132" as="geometry"/></mxCell><mxCell id="2a" value="POST /auth/register&#xa;POST /auth/login&#xa;POST /auth/logout&#xa;GET /auth/me" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="26" width="220" height="78" as="geometry"/></mxCell><mxCell id="2m" value="" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="104" width="220" height="28" as="geometry"/></mxCell><mxCell id="3" value="AuthController" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="365" y="270" width="220" height="132" as="geometry"/></mxCell><mxCell id="3a" value="- _store: DataStore" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="3m" value="+ register(data): dict&#xa;+ login(u,pw): tuple&#xa;+ logout(token)&#xa;+ get_current_user(token): dict" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="54" width="220" height="78" as="geometry"/></mxCell><mxCell id="4" value="User" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="182" as="geometry"/></mxCell><mxCell id="4a" value="- id: str&#xa;- username: str&#xa;- email: str&#xa;- password_hash: str&#xa;- role: str (ENUM)&#xa;- status: str (ENUM)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="26" width="220" height="114" as="geometry"/></mxCell><mxCell id="4m" value="+ to_safe_object(): dict&#xa;+ is_active(): bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="140" width="220" height="42" as="geometry"/></mxCell><mxCell id="5" value="DataStore" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="132" as="geometry"/></mxCell><mxCell id="5a" value="- _store: dict (in-memory)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="5m" value="+ save/get user&#xa;+ save/get/all campaign&#xa;+ save/get milestones&#xa;+ save/get session" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="54" width="220" height="78" as="geometry"/></mxCell><mxCell id="201" value="" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;" edge="1" source="2" target="3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="202" value="" style="endArrow=open;endFill=0;html=1;fontSize=10;" edge="1" source="3" target="4