<diagram name="1. Use Case Diagram" id="1__Use_Case_Diagram"><mxGraphModel pageWidth="640" pageHeight="320" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Diagram — G-09: Login" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="560" height="38" as="geometry"/></mxCell><mxCell id="sb" value="Fundraising Platform" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;fillColor=none;strokeColor=#000;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="130" y="58" width="440" height="210" as="geometry"/></mxCell><mxCell id="ac" value="Guest" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="44" y="118" width="40" height="60" as="geometry"/></mxCell><mxCell id="uc" value="&lt;b&gt;G-09&lt;/b&gt;&lt;br&gt;Login" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="210" y="108" width="210" height="75" as="geometry"/></mxCell><mxCell id="as" value="" style="endArrow=none;html=1;" edge="1" source="ac" target="uc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="2. UC Description" id="2__UC_Description"><mxGraphModel pageWidth="1100" pageHeight="800" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Description — G-09: Login" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="15" width="900" height="38" as="geometry"/></mxCell><mxCell id="bd" value="&lt;b&gt;Use Case ID:&lt;/b&gt;   G-09&lt;br/&gt;&lt;b&gt;Name:&lt;/b&gt;          Login&lt;br/&gt;&lt;b&gt;Actor(s):&lt;/b&gt;      Guest&lt;br/&gt;&lt;b&gt;Description:&lt;/b&gt;   A registered user authenticates and receives a session token for subsequent requests.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Preconditions:&lt;/b&gt;&lt;br/&gt;  • User has a registered account&lt;br/&gt;  • Account status is ACTIVE&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Main Flow:&lt;/b&gt;&lt;br/&gt;  1. User enters username and password&lt;br/&gt;  2. AuthController looks up user&lt;br/&gt;  3. Password hash verified&lt;br/&gt;  4. Session token generated and stored&lt;br/&gt;  5. Token returned&lt;br/&gt;  6. User redirected to role-specific dashboard&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Alternative / Exception Flows:&lt;/b&gt;&lt;br/&gt;  • A1 – Invalid credentials: 401&lt;br/&gt;  • A2 – Account SUSPENDED: 403&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Postconditions:&lt;/b&gt;&lt;br/&gt;  • User authenticated; session token issued" style="text;html=1;strokeColor=#23445D;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;spacingLeft=10;spacingTop=8;rounded=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="50" y="62" width="900" height="700" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="3. Sequence Diagram" id="3__Sequence_Diagram"><mxGraphModel pageWidth="1060" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="&lt;b&gt;Sequence Diagram — G-09: Login&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1000" height="34" as="geometry"/></mxCell><mxCell id="11" value=":Guest" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="5" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="12" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="86" as="sourcePoint"/><mxPoint x="87" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value=":AuthRoutes" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="14" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="86" as="sourcePoint"/><mxPoint x="290" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value=":AuthController" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="425" y="48" width="165" height="38" as="geometry"/></mxCell><mxCell id="16" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="86" as="sourcePoint"/><mxPoint x="510" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value=":User" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="645" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="18" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="86" as="sourcePoint"/><mxPoint x="730" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value=":DataStore" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="860" y="48" width="150" height="38" as="geometry"/></mxCell><mxCell id="20" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="86" as="sourcePoint"/><mxPoint x="950" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="POST /auth/login {username, password}" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="130" as="sourcePoint"/><mxPoint x="290" y="130" as="targetPoint"/></mxGeometry></mxCell><mxCell id="22" value="login(username, password)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="185" as="sourcePoint"/><mxPoint x="510" y="185" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="get_user_by_username(username)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="240" as="sourcePoint"/><mxPoint x="950" y="240" as="targetPoint"/></mxGeometry></mxCell><mxCell id="24" value="user" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="285" as="sourcePoint"/><mxPoint x="510" y="285" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="verify_password(hash)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="330" as="sourcePoint"/><mxPoint