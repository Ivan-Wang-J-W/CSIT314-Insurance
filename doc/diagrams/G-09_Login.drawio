<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="700" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — G-09: Login" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="users" value="users" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="172" as="geometry"/></mxCell><mxCell id="usersf" value="PK  id (UUID)&#xa;    username (VARCHAR 50, UNIQUE)&#xa;    email (VARCHAR 100, UNIQUE)&#xa;    password_hash (VARCHAR)&#xa;    role (ENUM)&#xa;    status (ENUM)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="users"><mxGeometry x="0" y="26" width="270" height="146" as="geometry"/></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="440" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
