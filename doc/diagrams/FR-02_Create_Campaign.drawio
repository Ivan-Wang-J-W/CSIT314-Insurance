<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="730" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — FR-02: Create Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="users" value="users" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="172" as="geometry"/></mxCell><mxCell id="usersf" value="PK  id (UUID)&#xa;    username (VARCHAR 50, UNIQUE)&#xa;    email (VARCHAR 100, UNIQUE)&#xa;    password_hash (VARCHAR)&#xa;    role (ENUM)&#xa;    status (ENUM)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="users"><mxGeometry x="0" y="26" width="270" height="146" as="geometry"/></mxCell><mxCell id="campaigns" value="campaigns" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="360" y="70" width="270" height="272" as="geometry"/></mxCell><mxCell id="campaignsf" value="PK  id (UUID)&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    category (VARCHAR 100)&#xa;    goal_amount (DECIMAL)&#xa;    raised_amount (DECIMAL)&#xa;    urgency_tier (ENUM)&#xa;    status (ENUM)&#xa;    image_url (VARCHAR)&#xa;    withdrawal_held (BOOLEAN)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="campaigns"><mxGeometry x="0" y="26" width="270" height="246" as="geometry"/></mxCell><mxCell id="101" value="1 creates *" style="endArrow=ERone;startArrow=ERmanyToOne;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="185" y="160" as="sourcePoint"/><mxPoint x="495" y="160" as="targetPoint"/></mxGeometry></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="750" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="6. UI Wireframe" id="6__UI_Wireframe"><mxGraphModel pageWidth="1090" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="hdr" value="UI Wireframe — FR-02: Create Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1060" height="34" as="geometry"/></mxCell><mxCell id="nav" value="Hello Goodbye  |  Browse  Campaigns  Donations  Notifications  [Logout]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="1060" height="38" as="geometry"/></mxCell><mxCell id="sb" value="📋 Dashboard&#xa;➕ Create Campaign&#xa;📁 My Campaigns&#xa;📊 Analytics&#xa;📜 History" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="96" width="175" height="280" as="geometry"/></mxCell><mxCell id="card" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#ccc;" vertex="1" parent="1"><mxGeometry x="195" y="96" width="875" height="660" as="geometry"/></mxCell><mxCell id="ct" value="Create New Campaign" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="106" width="835" height="36" as="geometry"/></mxCell><mxCell id="tfl" value="Title *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="152" width="835" height="20" as="geometry"/></mxCell><mxCell id="tfb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="215" y="174" width="835" height="34" as="geometry"/></mxCell><mxCell id="dl" value="Description *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="212" width="835" height="20" as="geometry"/></mxCell><mxCell id="db" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="215" y="234" width="835" height="60" as="geometry"/></mxCell><mxCell id="catl" value="Category *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="316" width="400" height="20" as="geometry"/></mxCell><mxCell id="catb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="215" y="338" width="400" height="34" as="geometry"/></mxCell><mxCell id="urgl" value="Urgency Tier *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="630" y="316" width="400" height="20" as="geometry"/></mxCell><mxCell id="urgb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="630" y="338" width="400" height="34" as="geometry"/></mxCell><mxCell id="goall" value="Goal Amount ($) *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="394" width="400" height="20" as="geometry"/></mxCell><mxCell id="goalb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="215" y="416" width="400" height="34" as="geometry"/></mxCell><mxCell id="durl" value="Duration (days) *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="630" y="394" width="400" height="20" as="geometry"/></mxCell><mxCell id="durb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="630" y="416" width="400" height="34" as="geometry"/></mxCell><mxCell id="imgl" value="Image URL" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="472" width="835" height="20" as="geometry"/></mxCell><mxCell id="imgb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="215" y="494" width="835" height="34" as="geometry"/></mxCell><mxCell id="sub" value="[ Submit Campaign for Review ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="215" y="540" width="835" height="44" as="geometry"/></mxCell></root></mxGraphModel></diagram>
