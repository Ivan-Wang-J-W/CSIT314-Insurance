<diagram name="1. Use Case Diagram" id="1__Use_Case_Diagram"><mxGraphModel pageWidth="640" pageHeight="320" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Diagram — FR-02: Create Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="560" height="38" as="geometry"/></mxCell><mxCell id="sb" value="Fundraising Platform" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;fillColor=none;strokeColor=#000;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="130" y="58" width="440" height="210" as="geometry"/></mxCell><mxCell id="ac" value="Fundraiser" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="44" y="118" width="40" height="60" as="geometry"/></mxCell><mxCell id="uc" value="&lt;b&gt;FR-02&lt;/b&gt;&lt;br&gt;Create Campaign" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="108" width="210" height="75" as="geometry"/></mxCell><mxCell id="as" value="" style="endArrow=none;html=1;" edge="1" source="ac" target="uc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="2. UC Description" id="2__UC_Description"><mxGraphModel pageWidth="1100" pageHeight="800" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Description — FR-02: Create Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="15" width="900" height="38" as="geometry"/></mxCell><mxCell id="bd" value="&lt;b&gt;Use Case ID:&lt;/b&gt;   FR-02&lt;br/&gt;&lt;b&gt;Name:&lt;/b&gt;          Create Campaign&lt;br/&gt;&lt;b&gt;Actor(s):&lt;/b&gt;      Fundraiser&lt;br/&gt;&lt;b&gt;Description:&lt;/b&gt;   A logged-in fundraiser submits a new fundraising campaign for platform review.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Preconditions:&lt;/b&gt;&lt;br/&gt;  • Fundraiser authenticated&lt;br/&gt;  • Account status is ACTIVE&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Main Flow:&lt;/b&gt;&lt;br/&gt;  1. Fundraiser fills title, description, category, goal, urgency tier, image URL, duration&lt;br/&gt;  2. Submits form (POST /api/campaigns)&lt;br/&gt;  3. CampaignController validates fields&lt;br/&gt;  4. Campaign entity created with status PENDING&lt;br/&gt;  5. DataStore persists; 201 Created&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Alternative / Exception Flows:&lt;/b&gt;&lt;br/&gt;  • A1 – Missing fields: 400 validation errors&lt;br/&gt;  • A2 – goal_amount &lt;= 0: validation error&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Postconditions:&lt;/b&gt;&lt;br/&gt;  • Campaign created with PENDING status&lt;br/&gt;  • Awaiting Platform Manager approval" style="text;html=1;strokeColor=#23445D;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;spacingLeft=10;spacingTop=8;rounded=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="50" y="62" width="900" height="700" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="3. Sequence Diagram" id="3__Sequence_Diagram"><mxGraphModel pageWidth="1060" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="&lt;b&gt;Sequence Diagram — FR-02: Create Campaign&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1000" height="34" as="geometry"/></mxCell><mxCell id="11" value=":Fundraiser" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="5" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="12" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="86" as="sourcePoint"/><mxPoint x="87" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value=":CampaignRoutes" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="14" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="86" as="sourcePoint"/><mxPoint x="290" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value=":CampaignController" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="425" y="48" width="170" height="38" as="geometry"/></mxCell><mxCell id="16" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="86" as="sourcePoint"/><mxPoint x="510" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value=":Campaign" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="645" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="18" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="86" as="sourcePoint"/><mxPoint x="730" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value=":DataStore" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="860" y="48" width="150" height="38" as="geometry"/></mxCell><mxCell id="20" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="86" as="sourcePoint"/><mxPoint x="950" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="POST /campaigns {data} + Bearer token" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="130" as="sourcePoint"/><mxPoint x="290" y="130" as="targetPoint"/></mxGeometry></mxCell><mxCell id="22" value="validate_token(token)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="185" as="sourcePoint"/><mxPoint x="510" y="185" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="fundraiser_id" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="215" as="sourcePoint"/><mxPoint x="290" y="215" as="targetPoint"/></mxGeometry></mxCell><mxCell id="24" value="create_campaign(data, fundraiser_id)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="260" as="sourcePoint"/><mxPoint x="510" y="260" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="Campaign(data, status=PENDING)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="315" as="sourcePoint"/><mxPoint x="730" y="315" as="targetPoint"/></mxGeometry></mxCell><mxCell id="26" value="campaign" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="350" as="sourcePoint"/><mxPoint x="510" y="350" as="targetPoint"/></mxGeometry></mxCell><mxCell id="27" value="save_campaign(campaign)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="398" as="sourcePoint"/><mxPoint x="950" y="398" as="targetPoint"/></mxGeometry></mxCell><mxCell id="28" value="campaign_id" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="433" as="sourcePoint"/><mxPoint x="510" y="433" as="targetPoint"/></mxGeometry></mxCell><mxCell id="29" value="{campaign}" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="478" as="sourcePoint"/><mxPoint x="290" y="478" as="targetPoint"/></mxGeometry></mxCell><mxCell id="30" value="201 Created + campaign JSON" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="526" as="sourcePoint"/><mxPoint x="87" y="526" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel></diagram>
<diagram name="4. Class Diagram" id="4__Class_Diagram"><mxGraphModel pageWidth="1000" pageHeight="860" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Class Diagram — FR-02: Create Campaign (BCE)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="900" height="38" as="geometry"/></mxCell><mxCell id="2" value="CampaignRoutes" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="365" y="65" width="220" height="186" as="geometry"/></mxCell><mxCell id="2a" value="GET /campaigns&#xa;POST /campaigns&#xa;GET /campaigns/{id}&#xa;POST /campaigns/{id}/reject&#xa;GET /campaigns/{id}/progress&#xa;POST /campaigns/{id}/milestones&#xa;GET /campaigns/history" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="26" width="220" height="132" as="geometry"/></mxCell><mxCell id="2m" value="" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="158" width="220" height="28" as="geometry"/></mxCell><mxCell id="3" value="CampaignController" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="365" y="270" width="220" height="150" as="geometry"/></mxCell><mxCell id="3a" value="- _store: DataStore" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="3m" value="+ list_campaigns(...): list&#xa;+ create_campaign(data,fid): dict&#xa;+ get_campaign_progress(id): dict&#xa;+ reject_campaign(id,rid,rmk)&#xa;+ search_campaign_history(...): list" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="54" width="220" height="96" as="geometry"/></mxCell><mxCell id="4" value="Campaign" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="236" as="geometry"/></mxCell><mxCell id="4a" value="- id: str&#xa;- title: str&#xa;- fundraiser_id: str&#xa;- goal_amount: float&#xa;- raised_amount: float&#xa;- urgency_tier: str&#xa;- status: str&#xa;- withdrawal_held: bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="26" width="220" height="150" as="geometry"/></mxCell><mxCell id="4m" value="+ progress_percent(): float&#xa;+ days_remaining(): int&#xa;+ is_completed(): bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="176" width="220" height="60" as="geometry"/></mxCell><mxCell id="5" value="DataStore" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="132" as="geometry"/></mxCell><mxCell id="5a" value="- _store: dict (in-memory)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="5m" value="+ save/get user&#xa;+ save/get/all campaign&#xa;+ save/get milestones&#xa;+ save/get session" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="54" width="220" height="78" as="geometry"/>