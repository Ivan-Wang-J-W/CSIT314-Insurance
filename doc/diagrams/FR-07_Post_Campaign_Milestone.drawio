<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="730" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — FR-07: Post Campaign Milestone" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="campaigns" value="campaigns" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="272" as="geometry"/></mxCell><mxCell id="campaignsf" value="PK  id (UUID)&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    category (VARCHAR 100)&#xa;    goal_amount (DECIMAL)&#xa;    raised_amount (DECIMAL)&#xa;    urgency_tier (ENUM)&#xa;    status (ENUM)&#xa;    image_url (VARCHAR)&#xa;    withdrawal_held (BOOLEAN)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="campaigns"><mxGeometry x="0" y="26" width="270" height="246" as="geometry"/></mxCell><mxCell id="milestones" value="milestones" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="360" y="70" width="270" height="152" as="geometry"/></mxCell><mxCell id="milestonesf" value="PK  id (UUID)&#xa;FK  campaign_id → campaigns.id&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="milestones"><mxGeometry x="0" y="26" width="270" height="126" as="geometry"/></mxCell><mxCell id="101" value="1 has *" style="endArrow=ERone;startArrow=ERmanyToOne;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="185" y="352" as="sourcePoint"/><mxPoint x="495" y="352" as="targetPoint"/></mxGeometry></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="750" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="6. UI Wireframe" id="6__UI_Wireframe"><mxGraphModel pageWidth="1090" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="hdr" value="UI Wireframe — FR-07: Post Campaign Milestone" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1060" height="34" as="geometry"/></mxCell><mxCell id="nav" value="Hello Goodbye  |  Browse  Campaigns  Donations  Notifications  [Logout]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="1060" height="38" as="geometry"/></mxCell><mxCell id="sb" value="📋 Dashboard&#xa;➕ Create Campaign&#xa;📁 My Campaigns&#xa;📊 Analytics&#xa;📜 History" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="96" width="175" height="280" as="geometry"/></mxCell><mxCell id="ct" value="Milestones — Clean Water Initiative" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="96" width="875" height="34" as="geometry"/></mxCell><mxCell id="st" value="Post an update visible to all donors and viewers." style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="132" width="875" height="24" as="geometry"/></mxCell><mxCell id="mtl" value="Milestone Title *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="162" width="875" height="20" as="geometry"/></mxCell><mxCell id="mtb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="195" y="184" width="875" height="34" as="geometry"/></mxCell><mxCell id="dl" value="Description *" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="226" width="875" height="20" as="geometry"/></mxCell><mxCell id="db" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="195" y="248" width="875" height="90" as="geometry"/></mxCell><mxCell id="sub" value="[ Post Milestone ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="350" width="875" height="42" as="geometry"/></mxCell><mxCell id="ph" value="Previous Milestones" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="195" y="410" width="875" height="28" as="geometry"/></mxCell><mxCell id="m1" value="2026-04-20 — Purchased equipment: 50 water purifiers bought and delivered." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="440" width="875" height="46" as="geometry"/></mxCell><mxCell id="m2" value="2026-04-10 — Site survey complete: 5 villages identified as beneficiaries." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="488" width="875" height="46" as="geometry"/></mxCell></root></mxGraphModel></diagram>
