<diagram name="1. Use Case Diagram" id="1__Use_Case_Diagram"><mxGraphModel pageWidth="640" pageHeight="320" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Diagram — FR-07: Post Campaign Milestone" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="560" height="38" as="geometry"/></mxCell><mxCell id="sb" value="Fundraising Platform" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;fillColor=none;strokeColor=#000;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="130" y="58" width="440" height="210" as="geometry"/></mxCell><mxCell id="ac" value="Fundraiser" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="44" y="118" width="40" height="60" as="geometry"/></mxCell><mxCell id="uc" value="&lt;b&gt;FR-07&lt;/b&gt;&lt;br&gt;Post Campaign Milestone" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="108" width="210" height="75" as="geometry"/></mxCell><mxCell id="as" value="" style="endArrow=none;html=1;" edge="1" source="ac" target="uc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="2. UC Description" id="2__UC_Description"><mxGraphModel pageWidth="1100" pageHeight="800" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Description — FR-07: Post Campaign Milestone" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="15" width="900" height="38" as="geometry"/></mxCell><mxCell id="bd" value="&lt;b&gt;Use Case ID:&lt;/b&gt;   FR-07&lt;br/&gt;&lt;b&gt;Name:&lt;/b&gt;          Post Campaign Milestone&lt;br/&gt;&lt;b&gt;Actor(s):&lt;/b&gt;      Fundraiser&lt;br/&gt;&lt;b&gt;Description:&lt;/b&gt;   A logged-in fundraiser posts a milestone update to their active campaign.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Preconditions:&lt;/b&gt;&lt;br/&gt;  • Fundraiser authenticated&lt;br/&gt;  • Campaign is ACTIVE and owned by the fundraiser&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Main Flow:&lt;/b&gt;&lt;br/&gt;  1. Fundraiser opens Milestones section&lt;br/&gt;  2. Fills title and description&lt;br/&gt;  3. Submits (POST /campaigns/{id}/milestones)&lt;br/&gt;  4. MilestoneController validates ownership&lt;br/&gt;  5. Milestone created and persisted&lt;br/&gt;  6. 201 Created; visible to all viewers&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Alternative / Exception Flows:&lt;/b&gt;&lt;br/&gt;  • A1 – Not owner: 403&lt;br/&gt;  • A2 – Campaign not ACTIVE: 400&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Postconditions:&lt;/b&gt;&lt;br/&gt;  • Milestone saved and publicly visible" style="text;html=1;strokeColor=#23445D;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;spacingLeft=10;spacingTop=8;rounded=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="50" y="62" width="900" height="700" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="3. Sequence Diagram" id="3__Sequence_Diagram"><mxGraphModel pageWidth="1060" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="&lt;b&gt;Sequence Diagram — FR-07: Post Campaign Milestone&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1000" height="34" as="geometry"/></mxCell><mxCell id="11" value=":Fundraiser" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="5" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="12" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="86" as="sourcePoint"/><mxPoint x="87" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value=":CampaignRoutes" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="14" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="86" as="sourcePoint"/><mxPoint x="290" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value=":MilestoneController" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="425" y="48" width="170" height="38" as="geometry"/></mxCell><mxCell id="16" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="86" as="sourcePoint"/><mxPoint x="510" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value=":Milestone" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="645" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="18" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="86" as="sourcePoint"/><mxPoint x="730" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value=":DataStore" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="860" y="48" width="150" height="38" as="geometry"/></mxCell><mxCell id="20" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="86" as="sourcePoint"/><mxPoint x="950" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="POST /campaigns/{id}/milestones {title,desc} + token" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="130" as="sourcePoint"/><mxPoint x="290" y="130" as="targetPoint"/></mxGeometry></mxCell><mxCell id="22" value="validate_token; check ownership" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="185" as="sourcePoint"/><mxPoint x="510" y="185" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="fundraiser_id" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="215" as="sourcePoint"/><mxPoint x="290" y="215" as="targetPoint"/></mxGeometry></mxCell><mxCell id="24" value="post_milestone(id,fundraiser_id,title,desc)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="260" as="sourcePoint"/><mxPoint x="510" y="260" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="get_campaign_by_id(id)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeome