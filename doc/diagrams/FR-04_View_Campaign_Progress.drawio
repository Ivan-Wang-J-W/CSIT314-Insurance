<diagram name="1. Use Case Diagram" id="1__Use_Case_Diagram"><mxGraphModel pageWidth="640" pageHeight="320" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Diagram — FR-04: View Campaign Progress" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="560" height="38" as="geometry"/></mxCell><mxCell id="sb" value="Fundraising Platform" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;fillColor=none;strokeColor=#000;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="130" y="58" width="440" height="210" as="geometry"/></mxCell><mxCell id="ac" value="Fundraiser" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="44" y="118" width="40" height="60" as="geometry"/></mxCell><mxCell id="uc" value="&lt;b&gt;FR-04&lt;/b&gt;&lt;br&gt;View Campaign Progress" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="108" width="210" height="75" as="geometry"/></mxCell><mxCell id="as" value="" style="endArrow=none;html=1;" edge="1" source="ac" target="uc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="2. UC Description" id="2__UC_Description"><mxGraphModel pageWidth="1100" pageHeight="800" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Description — FR-04: View Campaign Progress" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="15" width="900" height="38" as="geometry"/></mxCell><mxCell id="bd" value="&lt;b&gt;Use Case ID:&lt;/b&gt;   FR-04&lt;br/&gt;&lt;b&gt;Name:&lt;/b&gt;          View Campaign Progress&lt;br/&gt;&lt;b&gt;Actor(s):&lt;/b&gt;      Fundraiser&lt;br/&gt;&lt;b&gt;Description:&lt;/b&gt;   A logged-in fundraiser views real-time progress metrics for their campaign.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Preconditions:&lt;/b&gt;&lt;br/&gt;  • Fundraiser authenticated&lt;br/&gt;  • Campaign exists and belongs to the fundraiser&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Main Flow:&lt;/b&gt;&lt;br/&gt;  1. Fundraiser navigates to campaign&lt;br/&gt;  2. GET /campaigns/{id}/progress called&lt;br/&gt;  3. CampaignController retrieves campaign&lt;br/&gt;  4. Calls progress_percent() and days_remaining()&lt;br/&gt;  5. Returns {raised_amount, goal_amount, progress_percent, days_remaining}&lt;br/&gt;  6. Progress bar rendered&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Alternative / Exception Flows:&lt;/b&gt;&lt;br/&gt;  • A1 – Campaign not found: 404&lt;br/&gt;  • A2 – Not owner: 403&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Postconditions:&lt;/b&gt;&lt;br/&gt;  • Progress data displayed; no state changed" style="text;html=1;strokeColor=#23445D;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;spacingLeft=10;spacingTop=8;rounded=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="50" y="62" width="900" height="700" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="3. Sequence Diagram" id="3__Sequence_Diagram"><mxGraphModel pageWidth="1060" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="&lt;b&gt;Sequence Diagram — FR-04: View Campaign Progress&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1000" height="34" as="geometry"/></mxCell><mxCell id="11" value=":Fundraiser" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="5" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="12" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="86" as="sourcePoint"/><mxPoint x="87" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value=":CampaignRoutes" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="210" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="14" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="86" as="sourcePoint"/><mxPoint x="290" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value=":CampaignController" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="425" y="48" width="170" height="38" as="geometry"/></mxCell><mxCell id="16" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="86" as="sourcePoint"/><mxPoint x="510" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value=":Campaign" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="645" y="48" width="155" height="38" as="geometry"/></mxCell><mxCell id="18" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="86" as="sourcePoint"/><mxPoint x="730" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value=":DataStore" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="860" y="48" width="150" height="38" as="geometry"/></mxCell><mxCell id="20" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="86" as="sourcePoint"/><mxPoint x="950" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="GET /campaigns/{id}/progress" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="87" y="130" as="sourcePoint"/><mxPoint x="290" y="130" as="targetPoint"/></mxGeometry></mxCell><mxCell id="22" value="get_campaign_progress(id)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="185" as="sourcePoint"/><mxPoint x="510" y="185" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="get_campaign_by_id(id)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="240" as="sourcePoint"/><mxPoint x="950" y="240" as="targetPoint"/></mxGeometry></mxCell><mxCell id="24" value="campaign" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="950" y="280" as="sourcePoint"/><mxPoint x="510" y="280" as="targetPoint"/></mxGeometry></mxCell><mxCell id="25" value="progress_percent()" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="320" as="sourcePoint"/><mxPoint x="730" y="320" as="targetPoint"/></mxGeometry></mxCell><mxCell id="26" value="percent" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="353" as="sourcePoint"/><mxPoint x="510" y="353" as="targetPoint"/></mxGeometry></mxCell><mxCell id="27" value="days_remaining()" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="393" as="sourcePoint"/><mxPoint x="730" y="393" as="targetPoint"/></mxGeometry></mxCell><mxCell id="28" value="days" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="730" y="426" as="sourcePoint"/><mxPoint x="510" y="426" as="targetPoint"/></mxGeometry></mxCell><mxCell id="29" value="{raised,goal,progress_percent,days_remaining}" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="468" as="sourcePoint"/><mxPoint x="290" y="468" as="targetPoint"/></mxGeometry></mxCell><mxCell id="30" value="200 OK + progress JSON" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="290" y="516" as="sourcePoint"/><mxPoint x="87" y="516" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel></diagram>
<diagram name="4. Class Diagram" id="4__Class_Diagram"><mxGraphModel pageWidth="1000" pageHeight="860" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Class Diagram — FR-04: View Campaign Progress (BCE)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="900" height="38" as="geometry"/></mxCell><mxCell id="2" value="CampaignRoutes" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="365" y="65" width="220" height="186" as="geometry"/></mxCell><mxCell id="2a" value="GET /campaigns&#xa;POST /campaigns&#xa;GET /campaigns/{id}&#xa;POST /campaigns/{id}/reject&#xa;GET /campaigns/{id}/progress&#xa;POST /campaigns/{id}/milestones&#xa;GET /campaigns/history" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="26" width="220" height="132" as="geometry"/></mxCell><mxCell id="2m" value="" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="158" width="220" height="28" as="geometry"/></mxCell><mxCell id="3" value="CampaignController" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="365" y="270" width="220" height="150" as="geometry"/></mxCell><mxCell id="3a" value="- _store: DataStore" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="3m" value="+ list_campaigns(...): list&#xa;+ create_campaign(data,fid): dict&#xa;+ get_campaign_progress(id): dict&#xa;+ reject_campaign(id,rid,rmk)&#xa;+ search_campaign_history(...): list" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="54" width="220" height="96" as="geometry"/></mxCell><mxCell id="4" value="Campaign" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="236" as="geometry"/></mxCell><mxCell id="4a" value="- id: str&#xa;- title: str&#xa;- fundraiser_id: str&#xa;- goal_amount: float&#xa;- raised_amount: float&#xa;- urgency_tier: str&#xa;- status: str&#xa;- withdrawal_held: bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="26" width="220" height="150" as="geometry"/></mxCell><mxCell id="4m" value="+ progress_percent(): float&#xa;+ days_remaining(): int&#xa;+ is_completed(): bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="176" width="220" height="60" as="geometry"/></mxCell><mxCell id="5" value="DataStore" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="132" as="geometry"/></mxCell><mxCell id="5a" value="- _store: dict (in-memory)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="5m" value="+ save/get user&#xa;+ save/get/all campaign&#xa;+ save/get milestones&#xa;+ save/get session" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="54" width="220" height="78" as="geometry"/></mxCell><mxCell id="201" value="" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;" edge="1" source="2" target="3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="202" value="" style="endArrow=open;endFill=0;html=1;fontSize=10;" edge="1" source="3" target="4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="203" value="" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;" edge="1" source="3" target="5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="700" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — FR-04: View Campaign Progress" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="campaigns" value="campaigns" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="272" as="geometry"/></mxCell><mxCell id="campaignsf" value="PK  id (UUID)&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    category (VARCHAR 100)&#xa;    goal_amount (DECIMAL)&#xa;    raised_amount (DECIMAL)&#xa;    urgency_tier (ENUM)&#xa;    status (ENUM)&#xa;    image_url (VARCHAR)&#xa;    withdrawal_held (BOOLEAN)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="campaigns"><mxGeometry x="0" y="26" width="270" height="246" as="geometry"/></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="440" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="6. UI Wireframe" id="6__UI_Wireframe"><mxGraphModel pageWidth="1090" pageHeight="520" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="hdr" value="UI Wireframe — FR-04: View Campaign Progress" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1060" height="34" as="geometry"/></mxCell><mxCell id="nav" value="Hello Goodbye  |  Browse  Campaigns  Donations  Notifications  [Logout]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="1060" height="38" as="geometry"/></mxCell><mxCell id="sb" value="📋 Dashboard&#xa;➕ Create Campaign&#xa;📁 My Campaigns&#xa;📊 Analytics&#xa;📜 History" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="96" width="175" height="280" as="geometry"/></mxCell><mxCell id="ct" value="Clean Water Initiative" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="96" width="875" height="34" as="geometry"/></mxCell><mxCell id="st" value="Status: ACTIVE  |  Urgency: HIGH  |  Category: Healthcare" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="132" width="875" height="26" as="geometry"/></mxCell><mxCell id="s1" value="Raised&#xa;$7,800" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="166" width="210" height="78" as="geometry"/></mxCell><mxCell id="s2" value="Goal&#xa;$10,000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="419" y="166" width="210" height="78" as="geometry"/></mxCell><mxCell id="s3" value="Progress&#xa;78%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="643" y="166" width="210" height="78" as="geometry"/></mxCell><mxCell id="s4" value="Days Left&#xa;12" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="857" y="166" width="213" height="78" as="geometry"/></mxCell><mxCell id="pbl" value="Campaign Progress" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="254" width="875" height="24" as="geometry"/></mxCell><mxCell id="pbg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="195" y="280" width="875" height="28" as="geometry"/></mxCell><mxCell id="pbf" value="78%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="195" y="280" width="682" height="28" as="geometry"/></mxCell><mxCell id="dh" value="Date  |  Donor  |  Amount  |  Anonymous" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaa;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="330" width="875" height="32" as="geometry"/></mxCell><mxCell id="d1" value="2026-04-28  |  Anonymous  |  $500  |  Yes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="362" width="875" height="30" as="geometry"/></mxCell><mxCell id="d2" value="2026-04-27  |  John D.    |  $250  |  No" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="392" width="875" height="30" as="geometry"/></mxCell><mxCell id="d3" value="2026-04-25  |  Anonymous  |  $1,000  |  Yes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="422" width="875" height="30" as="geometry"/></mxCell></root></mxGraphModel></diagram>
