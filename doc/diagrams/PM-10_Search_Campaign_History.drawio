<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="700" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — PM-10: Search Campaign History" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="campaigns" value="campaigns" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="272" as="geometry"/></mxCell><mxCell id="campaignsf" value="PK  id (UUID)&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    category (VARCHAR 100)&#xa;    goal_amount (DECIMAL)&#xa;    raised_amount (DECIMAL)&#xa;    urgency_tier (ENUM)&#xa;    status (ENUM)&#xa;    image_url (VARCHAR)&#xa;    withdrawal_held (BOOLEAN)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="campaigns"><mxGeometry x="0" y="26" width="270" height="246" as="geometry"/></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="440" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="6. UI Wireframe" id="6__UI_Wireframe"><mxGraphModel pageWidth="1090" pageHeight="462" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="hdr" value="UI Wireframe — PM-10: Search Campaign History" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1060" height="34" as="geometry"/></mxCell><mxCell id="nav" value="Hello Goodbye  |  Browse  Campaigns  Donations  Notifications  [Logout]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="1060" height="38" as="geometry"/></mxCell><mxCell id="sb" value="📋 Dashboard&#xa;✅ Review Campaigns&#xa;📁 Campaign History&#xa;📊 Reports&#xa;⚙ Config" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="96" width="175" height="280" as="geometry"/></mxCell><mxCell id="ct" value="Campaign History" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="96" width="875" height="34" as="geometry"/></mxCell><mxCell id="fs" value="Status: [PENDING ✕] [ACTIVE ✕] [REJECTED ✕]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="136" width="400" height="36" as="geometry"/></mxCell><mxCell id="fc" value="Category: [All ▾]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="605" y="136" width="210" height="36" as="geometry"/></mxCell><mxCell id="fk" value="🔍 Keyword search..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#aaa;" vertex="1" parent="1"><mxGeometry x="825" y="136" width="245" height="36" as="geometry"/></mxCell><mxCell id="inf" value="Showing 38 campaigns (filtered)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="180" width="875" height="24" as="geometry"/></mxCell><mxCell id="th" value="ID  |  Title  |  Fundraiser  |  Category  |  Goal  |  Raised  |  Status  |  Date" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaa;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="210" width="875" height="34" as="geometry"/></mxCell><mxCell id="t1" value="CAM-001 | Clean Water Initiative | alice | Healthcare | $10k | $7.8k | ACTIVE | 2026-04-01" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="244" width="875" height="30" as="geometry"/></mxCell><mxCell id="t2" value="CAM-002 | Solar Panels for Schools | bob | Education | $50k | $0 | REJECTED | 2026-04-02" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="274" width="875" height="30" as="geometry"/></mxCell><mxCell id="t3" value="CAM-003 | Food Pantry Expansion | carol | Community | $5k | $5k | COMPLETED | 2026-03-15" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="304" width="875" height="30" as="geometry"/></mxCell><mxCell id="t4" value="CAM-004 | Emergency Medical Fund | dave | Healthcare | $20k | $3k | PENDING | 2026-04-28" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="334" width="875" height="30" as="geometry"/></mxCell><mxCell id="pg" value="← 1  2  3  4  →" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="445" y="374" width="200" height="36" as="geometry"/></mxCell></root></mxGraphModel></diagram>
