<diagram name="5. Data Persistence" id="5__Data_Persistence"><mxGraphModel pageWidth="700" pageHeight="600" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Data Persistence — PM-03: Reject Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="700" height="38" as="geometry"/></mxCell><mxCell id="campaigns" value="campaigns" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="270" height="272" as="geometry"/></mxCell><mxCell id="campaignsf" value="PK  id (UUID)&#xa;FK  fundraiser_id → users.id&#xa;    title (VARCHAR 200)&#xa;    description (TEXT)&#xa;    category (VARCHAR 100)&#xa;    goal_amount (DECIMAL)&#xa;    raised_amount (DECIMAL)&#xa;    urgency_tier (ENUM)&#xa;    status (ENUM)&#xa;    image_url (VARCHAR)&#xa;    withdrawal_held (BOOLEAN)&#xa;    created_at (TIMESTAMP)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="campaigns"><mxGeometry x="0" y="26" width="270" height="246" as="geometry"/></mxCell><mxCell id="nt" value="Current implementation: in-memory Python dict.&#xa;Each function has its SQLAlchemy equivalent commented inline.&#xa;To migrate to PostgreSQL: replace function bodies only." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;spacingLeft=6;spacingTop=4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="50" y="440" width="400" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="6. UI Wireframe" id="6__UI_Wireframe"><mxGraphModel pageWidth="1090" pageHeight="628" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="hdr" value="UI Wireframe — PM-03: Reject Campaign" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1060" height="34" as="geometry"/></mxCell><mxCell id="nav" value="Hello Goodbye  |  Browse  Campaigns  Donations  Notifications  [Logout]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#23445D;fontColor=#fff;strokeColor=none;fontSize=12;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="1060" height="38" as="geometry"/></mxCell><mxCell id="sb" value="📋 Dashboard&#xa;✅ Review Campaigns&#xa;📁 Campaign History&#xa;📊 Reports&#xa;⚙ Config" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="96" width="175" height="280" as="geometry"/></mxCell><mxCell id="ct" value="Pending Campaign Review" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="195" y="96" width="875" height="34" as="geometry"/></mxCell><mxCell id="th" value="ID  |  Title  |  Fundraiser  |  Goal  |  Submitted  |  Actions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaa;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="195" y="136" width="875" height="34" as="geometry"/></mxCell><mxCell id="r1" value="CAM-001 | Clean Water Initiative | alice | $10,000 | 2026-04-28 | [Approve] [Reject]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="170" width="875" height="32" as="geometry"/></mxCell><mxCell id="r2" value="CAM-002 | Solar Panels for Schools | bob | $50,000 | 2026-04-27 | [Approve] [Reject]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="202" width="875" height="32" as="geometry"/></mxCell><mxCell id="r3" value="CAM-003 | Food Pantry Expansion | carol | $5,000 | 2026-04-26 | [Approve] [Reject]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="195" y="234" width="875" height="32" as="geometry"/></mxCell><mxCell id="mod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="310" y="290" width="510" height="270" as="geometry"/></mxCell><mxCell id="mh" value="Reject Campaign — CAM-002" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="300" width="490" height="34" as="geometry"/></mxCell><mxCell id="ml" value="Rejection Remarks * (required)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="340" width="490" height="20" as="geometry"/></mxCell><mxCell id="mb" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="320" y="362" width="490" height="90" as="geometry"/></mxCell><mxCell id="mc" value="[ Cancel ]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="320" y="464" width="230" height="38" as="geometry"/></mxCell><mxCell id="mr" value="[ Confirm Reject ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b85450;fontColor=#fff;strokeColor=none;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="562" y="464" width="248" height="38" as="geometry"/></mxCell></root></mxGraphModel></diagram>
