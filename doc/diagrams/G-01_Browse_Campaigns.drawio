<diagram name="1. Use Case Diagram" id="1__Use_Case_Diagram"><mxGraphModel pageWidth="640" pageHeight="320" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Diagram — G-01: Browse Campaigns" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="560" height="38" as="geometry"/></mxCell><mxCell id="sb" value="Fundraising Platform" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;fillColor=none;strokeColor=#000;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="130" y="58" width="440" height="210" as="geometry"/></mxCell><mxCell id="ac" value="Guest / Public" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="44" y="118" width="40" height="60" as="geometry"/></mxCell><mxCell id="uc" value="&lt;b&gt;G-01&lt;/b&gt;&lt;br&gt;Browse Campaigns" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="210" y="108" width="210" height="75" as="geometry"/></mxCell><mxCell id="as" value="" style="endArrow=none;html=1;" edge="1" source="ac" target="uc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="2. UC Description" id="2__UC_Description"><mxGraphModel pageWidth="1100" pageHeight="800" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Use Case Description — G-01: Browse Campaigns" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="15" width="900" height="38" as="geometry"/></mxCell><mxCell id="bd" value="&lt;b&gt;Use Case ID:&lt;/b&gt;   G-01&lt;br/&gt;&lt;b&gt;Name:&lt;/b&gt;          Browse Campaigns&lt;br/&gt;&lt;b&gt;Actor(s):&lt;/b&gt;      Guest / Public&lt;br/&gt;&lt;b&gt;Description:&lt;/b&gt;   Any user (logged in or not) can view ACTIVE campaigns, filter by category or urgency tier, and search by keyword.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Preconditions:&lt;/b&gt;&lt;br/&gt;  • Platform is running&lt;br/&gt;  • At least one ACTIVE campaign exists&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Main Flow:&lt;/b&gt;&lt;br/&gt;  1. User opens platform&lt;br/&gt;  2. System retrieves ACTIVE campaigns from DataStore&lt;br/&gt;  3. Campaigns rendered as paginated cards&lt;br/&gt;  4. User optionally filters by category / urgency tier&lt;br/&gt;  5. User optionally searches by keyword&lt;br/&gt;  6. User clicks campaign card to view full details&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Alternative / Exception Flows:&lt;/b&gt;&lt;br/&gt;  • A1 – No campaigns: 'No campaigns available'&lt;br/&gt;  • A2 – Filter returns nothing: 'No results match your filter'&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Postconditions:&lt;/b&gt;&lt;br/&gt;  • Campaign list displayed&lt;br/&gt;  • No data modified" style="text;html=1;strokeColor=#23445D;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;overflow=hidden;spacingLeft=10;spacingTop=8;rounded=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="50" y="62" width="900" height="700" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram name="3. Sequence Diagram" id="3__Sequence_Diagram"><mxGraphModel pageWidth="1060" pageHeight="760" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="&lt;b&gt;Sequence Diagram — G-01: Browse Campaigns&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="8" width="1000" height="34" as="geometry"/></mxCell><mxCell id="11" value=":Public User" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1"><mxGeometry x="10" y="48" width="165" height="38" as="geometry"/></mxCell><mxCell id="12" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="92" y="86" as="sourcePoint"/><mxPoint x="92" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="13" value=":CampaignRoutes" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="225" y="48" width="165" height="38" as="geometry"/></mxCell><mxCell id="14" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="307" y="86" as="sourcePoint"/><mxPoint x="307" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="15" value=":CampaignController" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="463" y="48" width="165" height="38" as="geometry"/></mxCell><mxCell id="16" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="547" y="86" as="sourcePoint"/><mxPoint x="547" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="17" value=":DataStore" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="705" y="48" width="165" height="38" as="geometry"/></mxCell><mxCell id="18" value="" style="endArrow=none;dashed=1;html=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="787" y="86" as="sourcePoint"/><mxPoint x="787" y="710" as="targetPoint"/></mxGeometry></mxCell><mxCell id="19" value="GET /api/campaigns?filters" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="92" y="130" as="sourcePoint"/><mxPoint x="307" y="130" as="targetPoint"/></mxGeometry></mxCell><mxCell id="20" value="list_campaigns(urgency_tier,category,q)" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="307" y="185" as="sourcePoint"/><mxPoint x="547" y="185" as="targetPoint"/></mxGeometry></mxCell><mxCell id="21" value="get_all_campaigns()" style="endArrow=block;endFill=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="547" y="240" as="sourcePoint"/><mxPoint x="787" y="240" as="targetPoint"/></mxGeometry></mxCell><mxCell id="22" value="[campaigns]" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="787" y="288" as="sourcePoint"/><mxPoint x="547" y="288" as="targetPoint"/></mxGeometry></mxCell><mxCell id="23" value="[filtered campaigns]" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="547" y="336" as="sourcePoint"/><mxPoint x="307" y="336" as="targetPoint"/></mxGeometry></mxCell><mxCell id="24" value="200 OK + JSON" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="307" y="384" as="sourcePoint"/><mxPoint x="92" y="384" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel></diagram>
<diagram name="4. Class Diagram" id="4__Class_Diagram"><mxGraphModel pageWidth="1000" pageHeight="860" grid="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="tt" value="Class Diagram — G-01: Browse Campaigns (BCE)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="10" width="900" height="38" as="geometry"/></mxCell><mxCell id="2" value="CampaignRoutes" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="365" y="65" width="220" height="186" as="geometry"/></mxCell><mxCell id="2a" value="GET /campaigns&#xa;POST /campaigns&#xa;GET /campaigns/{id}&#xa;POST /campaigns/{id}/reject&#xa;GET /campaigns/{id}/progress&#xa;POST /campaigns/{id}/milestones&#xa;GET /campaigns/history" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="26" width="220" height="132" as="geometry"/></mxCell><mxCell id="2m" value="" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="2"><mxGeometry x="0" y="158" width="220" height="28" as="geometry"/></mxCell><mxCell id="3" value="CampaignController" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="365" y="270" width="220" height="150" as="geometry"/></mxCell><mxCell id="3a" value="- _store: DataStore" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="3m" value="+ list_campaigns(...): list&#xa;+ create_campaign(data,fid): dict&#xa;+ get_campaign_progress(id): dict&#xa;+ reject_campaign(id,rid,rmk)&#xa;+ search_campaign_history(...): list" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="3"><mxGeometry x="0" y="54" width="220" height="96" as="geometry"/></mxCell><mxCell id="4" value="Campaign" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="236" as="geometry"/></mxCell><mxCell id="4a" value="- id: str&#xa;- title: str&#xa;- fundraiser_id: str&#xa;- goal_amount: float&#xa;- raised_amount: float&#xa;- urgency_tier: str&#xa;- status: str&#xa;- withdrawal_held: bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="26" width="220" height="150" as="geometry"/></mxCell><mxCell id="4m" value="+ progress_percent(): float&#xa;+ days_remaining(): int&#xa;+ is_completed(): bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="4"><mxGeometry x="0" y="176" width="220" height="60" as="geometry"/></mxCell><mxCell id="5" value="DataStore" style="swimlane;fontStyle=1;align=center;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="365" y="510" width="220" height="132" as="geometry"/></mxCell><mxCell id="5a" value="- _store: dict (in-memory)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="26" width="220" height="28" as="geometry"/></mxCell><mxCell id="5m" value="+ save/get user&#xa;+ save/get/all campaign&#xa;+ save/get milestones&#xa;+ save/get session" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;overflow=hidden;fontSize=11;" vertex="1" parent="5"><mxGeometry x="0" y="54" width="220" height="78" as="geometry"/>